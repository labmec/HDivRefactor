            RowBox[{"4", ",", "1"}], "]"}], "]"}], " ", "+", " ", 
          RowBox[{"phivar", "[", 
           RowBox[{"[", 
            RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ")"}], 
        RowBox[{"(", 
         RowBox[{"chebx", "/.", 
          RowBox[{"x", "->", "csi"}]}], ")"}]}], "//", "Simplify"}]}], ";", 
     "\n", "\t", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"orders", ",", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"i", ",", "1"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "2", ",", "n"}], "}"}]}], "]"}]}], "]"}], ";", 
     "\n", "\t", 
     RowBox[{
      RowBox[{"phivar", "[", 
       RowBox[{"[", "8", "]"}], "]"}], " ", "=", " ", 
      RowBox[{
       RowBox[{"4", " ", 
        RowBox[{"phivar", "[", 
         RowBox[{"[", 
          RowBox[{"4", ",", "1"}], "]"}], "]"}], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"phivar", "[", 
           RowBox[{"[", 
            RowBox[{"1", ",", "1"}], "]"}], "]"}], " ", "+", " ", 
          RowBox[{"phivar", "[", 
           RowBox[{"[", 
            RowBox[{"2", ",", "1"}], "]"}], "]"}]}], ")"}], 
        RowBox[{"(", 
         RowBox[{"chebx", "/.", 
          RowBox[{"x", "->", "eta"}]}], ")"}]}], "//", "Simplify"}]}], ";", 
     "\n", "\t", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"orders", ",", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", "i"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "2", ",", "n"}], "}"}]}], "]"}]}], "]"}], ";", 
     "\n", "\t", "\n", "\t", 
     RowBox[{
      RowBox[{"phivar", "[", 
       RowBox[{"[", "9", "]"}], "]"}], " ", "=", " ", 
      RowBox[{
       RowBox[{"16", " ", 
        RowBox[{"phivar", "[", 
         RowBox[{"[", 
          RowBox[{"1", ",", "1"}], "]"}], "]"}], 
        RowBox[{"phivar", "[", 
         RowBox[{"[", 
          RowBox[{"3", ",", "1"}], "]"}], "]"}], 
        RowBox[{"Flatten", "[", 
