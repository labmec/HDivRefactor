Cell[BoxData[{
 RowBox[{"ClearAll", "[", "H1Basis", "]"}], "\n", 
 RowBox[{
  RowBox[{"H1Basis", "[", "n_", "]"}], ":=", " ", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "phivar", ",", "  ", "dphivar", ",", " ", "nshape", ",", " ", "subst", ",",
       " ", "chebx", ",", "x", ",", "orders", ",", "orderscsi", ",", 
      "orderseta"}], "}"}], ",", "\n", "\t", 
    RowBox[{
     RowBox[{"chebx", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"ChebyshevT", "[", 
         RowBox[{"i", ",", "x"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "0", ",", 
          RowBox[{"n", "-", "2"}]}], "}"}]}], "]"}]}], ";", "\n", "\t", 
     RowBox[{"nshape", " ", "=", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"n", "+", "1"}], ")"}], 
       RowBox[{"(", 
        RowBox[{"n", "+", "1"}], ")"}]}]}], ";", "\n", "\t", 
     RowBox[{"orders", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"{", 
          RowBox[{"1", ",", "1"}], "}"}], "}"}], ",", 
        RowBox[{"{", "4", "}"}]}], "]"}]}], ";", "\n", "\t", "\n", "\t", 
     RowBox[{"phivar", " ", "=", " ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", "}"}], ",", 
        RowBox[{"{", "9", "}"}]}], "]"}]}], ";", "\n", "\t\t", "\n", "\t", 
     RowBox[{
      RowBox[{"phivar", "[", 
       RowBox[{"[", "1", "]"}], "]"}], " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"1", "/", "4"}], 
        RowBox[{"(", 
         RowBox[{"1", "-", "csi"}], ")"}], 
        RowBox[{"(", 
         RowBox[{"1", "-", "eta"}], ")"}]}], "}"}]}], ";", "\n", "\t", 
     RowBox[{
      RowBox[{"phivar", "[", 
       RowBox[{"[", "2", "]"}], "]"}], " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"1", "/", "4"}], 
        RowBox[{"(", 
         RowBox[{"1", "+", "csi"}], ")"}], 
        RowBox[{"(", 
         RowBox[{"1", "-", "eta"}], ")"}]}], "}"}]}], ";", "\n", "\t", 
     RowBox[{
      RowBox[{"phivar", "[", 
       RowBox[{"[", "3", "]"}], "]"}], " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"1", "/", "4"}], 
        RowBox[{"(", 
         RowBox[{"1", "+", "csi"}], ")"}], 
        RowBox[{"(", 
         RowBox[{"1", "+", "eta"}], ")"}]}], "}"}]}], ";", "\n", "\t", 
     RowBox[{
      RowBox[{"phivar", "[", 
       RowBox[{"[", "4", "]"}], "]"}], " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"1", "/", "4"}], 
        RowBox[{"(", 
         RowBox[{"1", "-", "csi"}], ")"}], 
        RowBox[{"(", 
         RowBox[{"1", "+", "eta"}], ")"}]}], "}"}]}], ";", " ", "\n", "\t", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"n", "==", "1"}], ",", "\n", "\t\t", 
       RowBox[{
        RowBox[{"dphivar", "=", 
         RowBox[{"Grad", "[", 
          RowBox[{
           RowBox[{"Flatten", "[", "phivar", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"csi", ",", "eta"}], "}"}]}], "]"}]}], ";", "\n", "\t\t", 
        
        RowBox[{"Return", "[", 
         RowBox[{"{", 
          RowBox[{"phivar", ",", "dphivar", ",", "orders"}], "}"}], "]"}]}]}],
       "\n", "\t", "]"}], ";", "\n", "\t", "\n", "\t", 
     RowBox[{
      RowBox[{"phivar", "[", 
       RowBox[{"[", "5", "]"}], "]"}], " ", "=", " ", 
      RowBox[{
       RowBox[{"4", " ", 
        RowBox[{"phivar", "[", 
         RowBox[{"[", 
          RowBox[{"1", ",", "1"}], "]"}], "]"}], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"phivar", "[", 
           RowBox[{"[", 
            RowBox[{"2", ",", "1"}], "]"}], "]"}], " ", "+", " ", 
          RowBox[{"phivar", "[", 
           RowBox[{"[", 
            RowBox[{"3", ",", "1"}], "]"}], "]"}]}], ")"}], 
        RowBox[{"(", 
         RowBox[{"chebx", "/.", 
          RowBox[{"x", "->", "csi"}]}], ")"}]}], "//", "Simplify"}]}], ";", 
     "\n", "\t", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"orders", ",", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"i", ",", "1"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "2", ",", "n"}], "}"}]}], "]"}]}], "]"}], ";", 
     "\n", "\t", 
     RowBox[{
      RowBox[{"phivar", "[", 
       RowBox[{"[", "6", "]"}], "]"}], " ", "=", " ", 
      RowBox[{
       RowBox[{"4", " ", 
        RowBox[{"phivar", "[", 
         RowBox[{"[", 
          RowBox[{"2", ",", "1"}], "]"}], "]"}], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"phivar", "[", 
