            RowBox[{"i", ",", "2", ",", "n"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", "2", ",", "n"}], "}"}]}], "]"}], ",", "1"}], 
        "]"}]}], "]"}], ";", "\n", "\t", 
     RowBox[{"dphivar", "=", 
      RowBox[{
       RowBox[{"Grad", "[", 
        RowBox[{
         RowBox[{"Flatten", "[", "phivar", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"csi", ",", "eta"}], "}"}]}], "]"}], "//", "Simplify"}]}], ";",
      "\n", "\t\t", "\n", "\t", 
