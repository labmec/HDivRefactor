         RowBox[{"n", "+", "1"}]}], "}"}]}], "]"}], ",", "1"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"AllPolxy", "=", 
   RowBox[{"Join", "[", 
    RowBox[{"AllPolx", ",", "AllPoly"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"npoly", "=", 
  RowBox[{"Length", "[", "AllPolxy", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"nhdiv", "=", 
  RowBox[{"Length", "[", "HDivFuncs", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"allfunc", "=", 
   RowBox[{"Join", "[", 
    RowBox[{"AllPolxy", ",", "HDivFuncs"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"L2Mat", "=", 
   RowBox[{"Parallelize", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Quiet", "[", 
       RowBox[{"Integrate", "[", 
