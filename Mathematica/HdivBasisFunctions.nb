Cell[BoxData[{
 RowBox[{
  RowBox[{"AllPolx", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"csi", "^", "i"}], " ", 
          RowBox[{"eta", "^", "j"}]}], ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "0", ",", 
         RowBox[{"n", "+", "1"}]}], "}"}], ",", 
