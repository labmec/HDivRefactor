Cell[CellGroupData[{

Cell["HDiv functions with optimized border functions", "Chapter",
 CellChangeTimes->{{3.9727966057893972`*^9, 
  3.97279662779953*^9}},ExpressionUUID->"0aa55a49-4536-4210-bf13-\
8ccdc63c1a5e"],

Cell[CellGroupData[{

Cell["HDiv border functions", "Section",
 CellChangeTimes->{{3.9727966632753153`*^9, 
  3.9727966677882223`*^9}},ExpressionUUID->"4828ef9e-6afd-4262-925a-\
3201713a69f6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"HDivBorderBasis", "[", "n_", "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "v", ",", " ", "phidiv", ",", " ", "i", ",", " ", "j", ",", "aux", ",", 
      "phi", ",", "dphi", ",", "orders"}], "}"}], ",", "\n", "\t", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"phi", ",", "dphi", ",", "orders"}], "}"}], "=", 
      RowBox[{"H1Basis", "[", 
       RowBox[{"n", "+", "1"}], "]"}]}], ";", "\n", "\t", 
     RowBox[{"v", " ", "=", " ", 
      RowBox[{"VectorField", "[", "]"}]}], ";", "\n", "\t", "\n", "\t", 
     RowBox[{"phidiv", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", "}"}], ",", 
        RowBox[{"{", "5", "}"}]}], "]"}]}], ";", "\n", "\t", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"\"\<#phidiv \>\"", ",", 
         RowBox[{"8", "+", 
          RowBox[{"4", 
           RowBox[{"(", 
            RowBox[{"n", "-", "1"}], ")"}]}], "+", 
          RowBox[{"4", "n"}], "+", 
          RowBox[{"2", 
           RowBox[{"(", 
            RowBox[{"n", "-", "1"}], ")"}], "n"}]}]}], "]"}], ";"}], "*)"}], 
     "\n", "\t", 
     RowBox[{"aux", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
       "0", ",", "1", ",", "1", ",", "2", ",", "3", ",", "2", ",", "0", ",", 
        "3", ",", "4", ",", "5", ",", "6", ",", "7"}], "}"}]}], ";", "\n", 
     "\t", "\n", "\t", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", " ", 
       RowBox[{"i", "<=", "4"}], ",", " ", 
       RowBox[{"i", "++"}], ",", "\n", "\t\t", 
       RowBox[{
        RowBox[{"AppendTo", "[", 
         RowBox[{
          RowBox[{"phidiv", "[", 
           RowBox[{"[", "i", "]"}], "]"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"phi", "[", 
             RowBox[{"[", 
              RowBox[{
               RowBox[{
                RowBox[{"aux", "[", 
                 RowBox[{"[", 
                  RowBox[{
                   RowBox[{"2", "i"}], "-", "1"}], "]"}], "]"}], "+", "1"}], ",",
                "1"}], "]"}], "]"}], " ", 
            RowBox[{"v", "[", 
             RowBox[{"[", 
              RowBox[{
               RowBox[{"2", "i"}], "-", "1"}], "]"}], "]"}]}], "+", 
           RowBox[{
            RowBox[{"phi", "[", 
             RowBox[{"[", 
              RowBox[{
               RowBox[{
                RowBox[{"aux", "[", 
                 RowBox[{"[", 
                  RowBox[{"2", "i"}], "]"}], "]"}], "+", "1"}], ",", "1"}], 
              "]"}], "]"}], " ", 
            RowBox[{"v", "[", 
             RowBox[{"[", 
              RowBox[{"2", "i"}], "]"}], "]"}]}]}]}], "]"}], ";", "\n", 
        "\t\t", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"j", "=", "1"}], ",", 
          RowBox[{"j", "<=", "n"}], ",", 
          RowBox[{"j", "++"}], ",", "\n", "\t\t\t", 
          RowBox[{
           RowBox[{"AppendTo", "[", 
            RowBox[{
             RowBox[{"phidiv", "[", 
              RowBox[{"[", "i", "]"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", 
                RowBox[{"D", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"phi", "[", 
                    RowBox[{"[", 
                    RowBox[{"4", "+", "i"}], "]"}], "]"}], "[", 
                   RowBox[{"[", "j", "]"}], "]"}], ",", "eta"}], "]"}]}], ",", 
               RowBox[{"D", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"phi", "[", 
                   RowBox[{"[", "5", "]"}], "]"}], "[", 
                  RowBox[{"[", "j", "]"}], "]"}], ",", "csi"}], "]"}]}], 
              "}"}]}], "]"}], ";"}]}], "\n", "\t\t", "]"}], ";"}]}], "\n", 
      "\t", "]"}], ";", "\n", "\t", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "5"}], ",", 
       RowBox[{"i", "<=", "8"}], ",", 
       RowBox[{"i", "++"}], ",", "\n", "\t\t", 
       RowBox[{
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"j", "=", "1"}], ",", 
          RowBox[{"j", "<=", "n"}], ",", 
          RowBox[{"j", "++"}], ",", "\n", "\t\t\t", 
          RowBox[{
           RowBox[{"AppendTo", "[", 
            RowBox[{
             RowBox[{"phidiv", "[", 
              RowBox[{"[", "5", "]"}], "]"}], ",", 
             RowBox[{
              RowBox[{
               RowBox[{"phi", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "[", 
               RowBox[{"[", "j", "]"}], "]"}], 
              RowBox[{"v", "[", 
               RowBox[{"[", 
                RowBox[{"i", "+", "4"}], "]"}], "]"}]}]}], "]"}], ";"}]}], 
         "\n", "\t\t", "]"}], ";"}]}], "\n", "\t", "]"}], ";", "\n", "\t", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "<=", 
        RowBox[{"Length", "[", 
         RowBox[{"phi", "[", 
          RowBox[{"[", "9", "]"}], "]"}], "]"}]}], ",", 
       RowBox[{"i", "++"}], ",", "\n", "\t\t", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"orders", "[", 
             RowBox[{"[", 
              RowBox[{"9", ",", "i", ",", "1"}], "]"}], "]"}], "<=", 
            RowBox[{"n", "+", "1"}]}], " ", "&&", " ", 
           RowBox[{
            RowBox[{"orders", "[", 
             RowBox[{"[", 
              RowBox[{"9", ",", "i", ",", "2"}], "]"}], "]"}], "<=", "n"}]}], 
          ",", 
          RowBox[{"AppendTo", "[", 
           RowBox[{
            RowBox[{"phidiv", "[", 
             RowBox[{"[", "5", "]"}], "]"}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"phi", "[", 
               RowBox[{"[", "9", "]"}], "]"}], "[", 
              RowBox[{"[", "i", "]"}], "]"}], 
             RowBox[{"{", 
              RowBox[{"1", ",", "0"}], "}"}]}]}], "]"}]}], "]"}], ";", "\n", 
        "\t\t", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"orders", "[", 
             RowBox[{"[", 
              RowBox[{"9", ",", "i", ",", "1"}], "]"}], "]"}], "<=", "n"}], 
           " ", "&&", " ", 
           RowBox[{
            RowBox[{"orders", "[", 
             RowBox[{"[", 
              RowBox[{"9", ",", "i", ",", "2"}], "]"}], "]"}], "<=", 
            RowBox[{"n", "+", "1"}]}]}], ",", 
          RowBox[{"AppendTo", "[", 
           RowBox[{
            RowBox[{"phidiv", "[", 
             RowBox[{"[", "5", "]"}], "]"}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"phi", "[", 
               RowBox[{"[", "9", "]"}], "]"}], "[", 
              RowBox[{"[", "i", "]"}], "]"}], 
             RowBox[{"{", 
              RowBox[{"0", ",", "1"}], "}"}]}]}], "]"}]}], "]"}], ";"}]}], 
      "\n", "\t", "]"}], ";", "\n", "\t", "\n", "\t", "phidiv"}]}], "\n", 
   "]"}]}]], "Code",
 CellChangeTimes->{{3.888771376332448*^9, 3.888771571317981*^9}, {
