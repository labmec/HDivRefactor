Cell[BoxData[{
 RowBox[{
  RowBox[{"AllPolx", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"csi", "^", "i"}], " ", 
          RowBox[{"eta", "^", "j"}]}], ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "0", ",", 
         RowBox[{"n", "+", "1"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "0", ",", "n"}], "}"}]}], "]"}], ",", "1"}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"AllPoly", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", 
         RowBox[{
          RowBox[{"csi", "^", "i"}], " ", 
          RowBox[{"eta", "^", "j"}]}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "0", ",", "n"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "0", ",", 
         RowBox[{"n", "+", "1"}]}], "}"}]}], "]"}], ",", "1"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"AllPolxy", "=", 
   RowBox[{"Join", "[", 
    RowBox[{"AllPolx", ",", "AllPoly"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"npoly", "=", 
  RowBox[{"Length", "[", "AllPolxy", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"nhdiv", "=", 
  RowBox[{"Length", "[", "HDivFuncs", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"allfunc", "=", 
   RowBox[{"Join", "[", 
    RowBox[{"AllPolxy", ",", "HDivFuncs"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"L2Mat", "=", 
   RowBox[{"Parallelize", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Quiet", "[", 
       RowBox[{"Integrate", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"allfunc", "[", 
           RowBox[{"[", "i", "]"}], "]"}], ".", 
          RowBox[{"allfunc", "[", 
           RowBox[{"[", "j", "]"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"csi", ",", 
           RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"eta", ",", 
           RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", 
        RowBox[{"Length", "[", "allfunc", "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"j", ",", "1", ",", 
        RowBox[{"Length", "[", "allfunc", "]"}]}], "}"}]}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"L2Mat", "//", "MatrixForm"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nL2", "=", 
   RowBox[{"Length", "[", "AllPolxy", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Res", "=", 
    RowBox[{
     RowBox[{"L2Mat", "[", 
      RowBox[{"[", 
       RowBox[{
        RowBox[{
         RowBox[{"nL2", "+", "1"}], ";;"}], ",", 
        RowBox[{
         RowBox[{"nL2", "+", "1"}], ";;"}]}], "]"}], "]"}], "-", 
     RowBox[{
      RowBox[{"L2Mat", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{
          RowBox[{"nL2", "+", "1"}], ";;"}], ",", 
         RowBox[{"1", ";;", "nL2"}]}], "]"}], "]"}], ".", 
      RowBox[{"LinearSolve", "[", 
       RowBox[{
        RowBox[{"L2Mat", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"1", ";;", "nL2"}], ",", 
           RowBox[{"1", ";;", "nL2"}]}], "]"}], "]"}], ",", 
        RowBox[{"L2Mat", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"1", ";;", "nL2"}], ",", 
           RowBox[{
            RowBox[{"nL2", "+", "1"}], ";;"}]}], "]"}], "]"}]}], "]"}]}]}]}], 
   ";"}], "\[IndentingNewLine]", 
