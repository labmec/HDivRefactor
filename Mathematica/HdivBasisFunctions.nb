            RowBox[{"3", ",", "1"}], "]"}], "]"}], " ", "+", " ", 
          RowBox[{"phivar", "[", 
           RowBox[{"[", 
            RowBox[{"4", ",", "1"}], "]"}], "]"}]}], ")"}], 
        RowBox[{"(", 
         RowBox[{"chebx", "/.", 
          RowBox[{"x", "->", "eta"}]}], ")"}]}], "//", "Simplify"}]}], ";", 
     "\n", "\t", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"orders", ",", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", "i"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "2", ",", "n"}], "}"}]}], "]"}]}], "]"}], ";", 
     "\n", "\t", 
     RowBox[{
      RowBox[{"phivar", "[", 
       RowBox[{"[", "7", "]"}], "]"}], " ", "=", " ", 
      RowBox[{
       RowBox[{"4", " ", 
        RowBox[{"phivar", "[", 
         RowBox[{"[", 
          RowBox[{"3", ",", "1"}], "]"}], "]"}], 
        RowBox[{"(", 
