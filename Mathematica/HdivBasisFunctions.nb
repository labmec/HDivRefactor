61b581102b47"],

Cell[CellGroupData[{

Cell["The div(Hdiv) functions can be represented by L2 functions", "Section",
 CellChangeTimes->{{3.972793568842372*^9, 3.972793586777347*^9}, {
  3.9727949947360573`*^9, 
  3.972795009196711*^9}},ExpressionUUID->"8b92cab6-4ee9-4568-8eff-\
103131d0d6a8"],

Cell[BoxData[{
 RowBox[{"n", "=", "2"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"L2Funcs", "=", 
   RowBox[{"H1Basis", "[", "n", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"HDivFuncs", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{
     RowBox[{"HDivOptimizedBasis", "[", "n", "]"}], ",", "1"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"L2", "=", 
   RowBox[{
    RowBox[{"L2Funcs", "[", 
     RowBox[{"[", "1", "]"}], "]"}], "//", "Flatten"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"div", "=", 
  RowBox[{
   RowBox[{"Div", "[", 
    RowBox[{"HDivFuncs", ",", 
     RowBox[{"{", 
      RowBox[{"csi", ",", "eta"}], "}"}]}], "]"}], "//", "Simplify"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"allfunc", "=", 
   RowBox[{"Join", "[", 
    RowBox[{"L2", ",", "div"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"L2Mat", "=", 
   RowBox[{"Parallelize", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Quiet", "[", 
       RowBox[{"Integrate", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"allfunc", "[", 
           RowBox[{"[", "i", "]"}], "]"}], 
          RowBox[{"allfunc", "[", 
           RowBox[{"[", "j", "]"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"csi", ",", 
           RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"eta", ",", 
           RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", 
        RowBox[{"Length", "[", "allfunc", "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"j", ",", "1", ",", 
        RowBox[{"Length", "[", "allfunc", "]"}]}], "}"}]}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"L2Mat", "//", "MatrixForm"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nL2", "=", 
   RowBox[{"Length", "[", "L2", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Res", "=", 
    RowBox[{
     RowBox[{"L2Mat", "[", 
      RowBox[{"[", 
       RowBox[{
        RowBox[{
         RowBox[{"nL2", "+", "1"}], ";;"}], ",", 
        RowBox[{
         RowBox[{"nL2", "+", "1"}], ";;"}]}], "]"}], "]"}], "-", 
     RowBox[{
      RowBox[{"L2Mat", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{
          RowBox[{"nL2", "+", "1"}], ";;"}], ",", 
         RowBox[{"1", ";;", "nL2"}]}], "]"}], "]"}], ".", 
      RowBox[{"LinearSolve", "[", 
       RowBox[{
        RowBox[{"L2Mat", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"1", ";;", "nL2"}], ",", 
           RowBox[{"1", ";;", "nL2"}]}], "]"}], "]"}], ",", 
        RowBox[{"L2Mat", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"1", ";;", "nL2"}], ",", 
           RowBox[{
            RowBox[{"nL2", "+", "1"}], ";;"}]}], "]"}], "]"}]}], "]"}]}]}]}], 
   ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Chop", "[", "Res", "]"}], "//", "MatrixForm"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"Norm", "[", "Res", "]"}]}], "Input",
 CellChangeTimes->{{3.972793737232115*^9, 3.9727938587828608`*^9}, {
   3.972793916655428*^9, 3.972793981869404*^9}, {3.972794015754818*^9, 
