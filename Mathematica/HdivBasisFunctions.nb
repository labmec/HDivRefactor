       "Simplify"}]}], ";", "\n", "\t", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"orders", ",", 
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
