Cell[CellGroupData[{

Cell["\<\
HDiv Functions with separated divergence free and nonsingular div\
\>", "Chapter",
 CellChangeTimes->{{3.97279715922786*^9, 
  3.972797186344153*^9}},ExpressionUUID->"55a7b01e-c180-4e7b-afe5-\
f363c4a1320b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"HDivOptimizedBasis", "[", "n_", "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "v", ",", " ", "phidiv", ",", " ", "i", ",", " ", "j", ",", "aux", ",", 
      "phi", ",", "dphi", ",", "orders"}], "}"}], ",", "\n", "\t", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"phi", ",", "dphi", ",", "orders"}], "}"}], "=", 
      RowBox[{"H1Basis", "[", 
       RowBox[{"n", "+", "1"}], "]"}]}], ";", "\n", "\t", 
     RowBox[{"v", " ", "=", " ", 
      RowBox[{"VectorField", "[", "]"}]}], ";", "\n", "\t", "\n", "\t", 
     RowBox[{"phidiv", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", "}"}], ",", 
        RowBox[{"{", "10", "}"}]}], "]"}]}], ";", "\n", "\t", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"\"\<#phidiv \>\"", ",", 
         RowBox[{"8", "+", 
          RowBox[{"4", 
           RowBox[{"(", 
            RowBox[{"n", "-", "1"}], ")"}]}], "+", 
          RowBox[{"4", "n"}], "+", 
          RowBox[{"2", 
           RowBox[{"(", 
            RowBox[{"n", "-", "1"}], ")"}], "n"}]}]}], "]"}], ";"}], "*)"}], 
     "\n", "\t", 
     RowBox[{"aux", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
       "0", ",", "1", ",", "1", ",", "2", ",", "3", ",", "2", ",", "0", ",", 
        "3", ",", "4", ",", "5", ",", "6", ",", "7"}], "}"}]}], ";", "\n", 
     "\t", "\n", "\t", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", " ", 
       RowBox[{"i", "<=", "4"}], ",", " ", 
       RowBox[{"i", "++"}], ",", "\n", "\t\t", 
       RowBox[{
        RowBox[{"AppendTo", "[", 
         RowBox[{
          RowBox[{"phidiv", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"2", "i"}], "-", "1"}], "]"}], "]"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"phi", "[", 
             RowBox[{"[", 
              RowBox[{
               RowBox[{
                RowBox[{"aux", "[", 
                 RowBox[{"[", 
                  RowBox[{
                   RowBox[{"2", "i"}], "-", "1"}], "]"}], "]"}], "+", "1"}], ",",
                "1"}], "]"}], "]"}], " ", 
            RowBox[{"v", "[", 
             RowBox[{"[", 
              RowBox[{
               RowBox[{"2", "i"}], "-", "1"}], "]"}], "]"}]}], "+", 
           RowBox[{
            RowBox[{"phi", "[", 
             RowBox[{"[", 
              RowBox[{
               RowBox[{
                RowBox[{"aux", "[", 
                 RowBox[{"[", 
                  RowBox[{"2", "i"}], "]"}], "]"}], "+", "1"}], ",", "1"}], 
              "]"}], "]"}], " ", 
            RowBox[{"v", "[", 
             RowBox[{"[", 
              RowBox[{"2", "i"}], "]"}], "]"}]}]}]}], "]"}], ";", "\n", 
        "\t\t", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"j", "=", "1"}], ",", 
          RowBox[{"j", "<=", "n"}], ",", 
          RowBox[{"j", "++"}], ",", "\n", "\t\t\t", 
          RowBox[{
           RowBox[{"AppendTo", "[", 
            RowBox[{
             RowBox[{"phidiv", "[", 
              RowBox[{"[", 
               RowBox[{"2", "i"}], "]"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", 
                RowBox[{"D", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"phi", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", "+", "4"}], "]"}], "]"}], "[", 
                   RowBox[{"[", "j", "]"}], "]"}], ",", "eta"}], "]"}]}], ",", 
               RowBox[{"D", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"phi", "[", 
                   RowBox[{"[", 
                    RowBox[{"i", "+", "4"}], "]"}], "]"}], "[", 
                  RowBox[{"[", "j", "]"}], "]"}], ",", "csi"}], "]"}]}], 
              "}"}]}], "]"}], ";"}]}], "\n", "\t\t", "]"}], ";"}]}], "\n", 
      "\t", "]"}], ";", "\n", "\t", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "5"}], ",", 
       RowBox[{"i", "<=", "7"}], ",", 
       RowBox[{"i", "++"}], ",", "\n", "\t\t", 
       RowBox[{
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"j", "=", "1"}], ",", 
          RowBox[{"j", "<=", "n"}], ",", 
          RowBox[{"j", "++"}], ",", "\n", "\t\t\t", 
          RowBox[{
           RowBox[{"AppendTo", "[", 
            RowBox[{
             RowBox[{"phidiv", "[", 
              RowBox[{"[", "9", "]"}], "]"}], ",", 
             RowBox[{
              RowBox[{
               RowBox[{"phi", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "[", 
               RowBox[{"[", "j", "]"}], "]"}], 
              RowBox[{"v", "[", 
               RowBox[{"[", 
                RowBox[{"i", "+", "4"}], "]"}], "]"}]}]}], "]"}], ";"}]}], 
         "\n", "\t\t", "]"}], ";"}]}], "\n", "\t", "]"}], ";", "\n", "\t", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "<=", 
        RowBox[{"Length", "[", 
         RowBox[{"phi", "[", 
          RowBox[{"[", "9", "]"}], "]"}], "]"}]}], ",", 
       RowBox[{"i", "++"}], ",", "\n", "\t\t", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"orders", "[", 
             RowBox[{"[", 
              RowBox[{"9", ",", "i", ",", "1"}], "]"}], "]"}], "<=", 
            RowBox[{"n", "+", "1"}]}], " ", "&&", " ", 
           RowBox[{
            RowBox[{"orders", "[", 
             RowBox[{"[", 
              RowBox[{"9", ",", "i", ",", "2"}], "]"}], "]"}], "<=", "n"}]}], 
          ",", 
          RowBox[{"AppendTo", "[", 
           RowBox[{
            RowBox[{"phidiv", "[", 
             RowBox[{"[", "9", "]"}], "]"}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"phi", "[", 
               RowBox[{"[", "9", "]"}], "]"}], "[", 
              RowBox[{"[", "i", "]"}], "]"}], 
             RowBox[{"{", 
              RowBox[{"1", ",", "0"}], "}"}]}]}], "]"}]}], "]"}], ";"}]}], 
      "\n", "\t", "]"}], ";", "\n", "\t", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"j", "=", "1"}], ",", 
       RowBox[{"j", "<=", 
        RowBox[{
         RowBox[{"(", "n", ")"}], 
         RowBox[{"(", "n", ")"}]}]}], ",", 
       RowBox[{"j", "++"}], ",", "\n", "\t", 
       RowBox[{
        RowBox[{"AppendTo", "[", 
         RowBox[{
          RowBox[{"phidiv", "[", 
           RowBox[{"[", "10", "]"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"D", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"phi", "[", 
                 RowBox[{"[", "9", "]"}], "]"}], "[", 
                RowBox[{"[", "j", "]"}], "]"}], ",", "eta"}], "]"}]}], ",", 
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"phi", "[", 
                RowBox[{"[", "9", "]"}], "]"}], "[", 
               RowBox[{"[", "j", "]"}], "]"}], ",", "csi"}], "]"}]}], "}"}]}],
          "]"}], ";"}]}], "\n", "\t", "]"}], ";", "\n", "\t", "\n", "\t", 
     "phidiv"}]}], "\n", "]"}]}]], "Code",
 CellChangeTimes->{{3.888771376332448*^9, 3.888771571317981*^9}, {
   3.888771623368643*^9, 3.88877195908783*^9}, {3.888772104857011*^9, 
