              RowBox[{"[", "i", "]"}], "]"}], 
             RowBox[{"{", 
              RowBox[{"0", ",", "1"}], "}"}]}]}], "]"}]}], "]"}], ";"}]}], 
      "\n", "\t", "]"}], ";", "\n", "\t", "\n", "\t", "phidiv"}]}], "\n", 
