Cell[BoxData[
 RowBox[{
  RowBox[{"HDivBasis", "[", "n_", "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "v", ",", " ", "phidiv", ",", " ", "i", ",", " ", "j", ",", "aux", ",", 
      "phi", ",", "dphi", ",", "orders"}], "}"}], ",", "\n", "\t", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"phi", ",", "dphi", ",", "orders"}], "}"}], "=", 
      RowBox[{"H1Basis", "[", 
       RowBox[{"n", "+", "1"}], "]"}]}], ";", "\n", "\t", 
     RowBox[{"v", " ", "=", " ", 
      RowBox[{"VectorField", "[", "]"}]}], ";", "\n", "\t", "\n", "\t", 
     RowBox[{"phidiv", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", "}"}], ",", 
        RowBox[{"{", "5", "}"}]}], "]"}]}], ";", "\n", "\t", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"\"\<#phidiv \>\"", ",", 
         RowBox[{"8", "+", 
          RowBox[{"4", 
           RowBox[{"(", 
            RowBox[{"n", "-", "1"}], ")"}]}], "+", 
          RowBox[{"4", "n"}], "+", 
          RowBox[{"2", 
           RowBox[{"(", 
